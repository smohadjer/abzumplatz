{
    "type": "object",
    "properties": {
        "_id": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "allOf": [
                {
                    "maxLength": 100,
                    "errorMessage": "Der Name ist zu lang."
                }
            ]
        },
        "courts_count": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 20,
                    "errorMessage": "Die Anzahl der Plätze muss zwischen 1 und 19 liegen."
                }
            ]
        },
        "start_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Startzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "end_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Endzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "reservations_limit": {
            "type": "integer"
        }
    },
    "required": ["name", "courts_count"],
    "additionalProperties": false
}
