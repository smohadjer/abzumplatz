{
    "type": "object",
    "properties": {
        "_id": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "allOf": [
                {
                    "maxLength": 100,
                    "errorMessage": "Der Name ist zu lang."
                }
            ]
        },
        "address_line1": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 5,
                    "errorMessage": "Die Adresse ist zu kurz."
                },
                {
                    "maxLength": 120,
                    "errorMessage": "Die Adresse ist zu lang."
                }
            ]
        },
        "postal_code": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 3,
                    "errorMessage": "Die PLZ ist zu kurz."
                },
                {
                    "maxLength": 20,
                    "errorMessage": "Die PLZ ist zu lang."
                }
            ]
        },
        "city": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 2,
                    "errorMessage": "Der Ort ist zu kurz."
                },
                {
                    "maxLength": 80,
                    "errorMessage": "Der Ort ist zu lang."
                }
            ]
        },
        "country": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 2,
                    "errorMessage": "Das Land ist zu kurz."
                },
                {
                    "maxLength": 80,
                    "errorMessage": "Das Land ist zu lang."
                }
            ]
        },
        "plan_type": {
            "type": "string",
            "enum": ["free", "paid"],
            "errorMessage": {
                "enum": "Bitte wählen Sie einen gültigen Plan aus."
            }
        },
        "courts_count": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 20,
                    "errorMessage": "Die Anzahl der Plätze muss zwischen 1 und 19 liegen."
                }
            ]
        },
        "start_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Startzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "end_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Endzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "timezone": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 3,
                    "errorMessage": "Bitte geben Sie eine gültige Zeitzone an."
                },
                {
                    "maxLength": 100,
                    "errorMessage": "Die Zeitzone ist zu lang."
                }
            ]
        },
        "reservations_limit": {
            "type": "integer"
        }
    },
    "required": ["name", "address_line1", "postal_code", "city", "country", "plan_type", "courts_count", "start_hour", "end_hour", "timezone"],
    "additionalProperties": false
}
