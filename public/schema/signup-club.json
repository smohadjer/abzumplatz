{
    "type": "object",
    "properties": {
        "first_name": {
            "type": "string",
            "allOf": [
                {
                    "pattern": "^[A-Za-z]+$",
                    "errorMessage": "Es sind nur Buchstaben erlaubt."
                },
                {
                    "minLength": 2,
                    "errorMessage": "Der Name ist zu kurz."
                },
                {
                    "maxLength": 40,
                    "errorMessage": "Der Name ist zu lang."
                }
            ]
        },
        "last_name": {
            "type": "string",
            "allOf": [
                {
                    "pattern": "^[A-Za-z-]+$",
                    "errorMessage": "Es sind nur Buchstaben und Bindestriche erlaubt."
                },
                {
                    "minLength": 2,
                    "errorMessage": "Der Name ist zu kurz."
                },
                {
                    "maxLength": 40,
                    "errorMessage": "Der Name ist zu lang."
                }
            ]
        },
        "email": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 6,
                    "errorMessage": "Die E-Mail-Adresse muss mindestens 6 Zeichen lang sein."
                },
                {
                    "maxLength": 127,
                    "errorMessage": "Die E-Mail-Adresse ist zu lang."
                },
                {
                    "pattern": "^[a-zA-Z0-9.!#$%&'*+\\/?=^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$",
                    "errorMessage": "Dies ist keine gültige E-Mail-Adresse."
                }
            ]
        },
        "password": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 8,
                    "errorMessage": "Das Passwort muss mindestens 8 Zeichen lang sein."
                },
                {
                    "pattern": "(?=.*[a-z])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens einen Kleinbuchstaben enthalten."
                },
                {
                    "pattern": "(?=.*[A-Z])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens einen Großbuchstaben enthalten."
                },
                {
                    "pattern": "(?=.*\\d)",
                    "errorMessage": "Das Passwort muss mindestens eine Zahl enthalten."
                },
                {
                    "pattern": "(?=.*[^a-zA-Z\\d])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens ein Sonderzeichen enthalten."
                }
            ]
        },
        "privacy": {
            "enum": ["agree"],
            "errorMessage": {
                "enum": "Dies ist kein gültiger Wert."
            }
        },
        "name": {
            "type": "string",
            "allOf": [
                {
                    "maxLength": 100,
                    "errorMessage": "Der Name ist zu lang."
                }
            ]
        },
        "address_line1": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 5,
                    "errorMessage": "Die Adresse ist zu kurz."
                },
                {
                    "maxLength": 120,
                    "errorMessage": "Die Adresse ist zu lang."
                }
            ]
        },
        "postal_code": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 3,
                    "errorMessage": "Die PLZ ist zu kurz."
                },
                {
                    "maxLength": 20,
                    "errorMessage": "Die PLZ ist zu lang."
                }
            ]
        },
        "city": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 2,
                    "errorMessage": "Der Ort ist zu kurz."
                },
                {
                    "maxLength": 80,
                    "errorMessage": "Der Ort ist zu lang."
                }
            ]
        },
        "country": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 2,
                    "errorMessage": "Das Land ist zu kurz."
                },
                {
                    "maxLength": 80,
                    "errorMessage": "Das Land ist zu lang."
                }
            ]
        },
        "plan_type": {
            "type": "string",
            "enum": ["free", "paid"],
            "errorMessage": {
                "enum": "Bitte wählen Sie einen gültigen Plan aus."
            }
        },
        "courts_count": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 20,
                    "errorMessage": "Die Anzahl der Plätze muss zwischen 1 und 19 liegen."
                }
            ]
        },
        "start_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Startzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "end_hour": {
            "type": "integer",
            "allOf": [
                {
                    "minimum": 1,
                    "exclusiveMaximum": 24,
                    "errorMessage": "Die Endzeit muss zwischen 1 und 23 Uhr liegen."
                }
            ]
        },
        "timezone": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 3,
                    "errorMessage": "Bitte geben Sie eine gültige Zeitzone an."
                },
                {
                    "maxLength": 100,
                    "errorMessage": "Die Zeitzone ist zu lang."
                }
            ]
        },
        "reservations_limit": {
            "type": "integer"
        }
    },
    "required": ["first_name", "last_name", "email", "password", "privacy", "name", "address_line1", "postal_code", "city", "country", "plan_type", "courts_count", "start_hour", "end_hour", "timezone"],
    "additionalProperties": false
}
