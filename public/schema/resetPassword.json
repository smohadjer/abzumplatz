{
    "type": "object",
    "properties": {
        "resetToken": {
            "type": "string"
        },
        "password": {
            "type": "string",
            "allOf": [
                {
                    "minLength": 8,
                    "errorMessage": "Das Passwort muss mindestens 8 Zeichen lang sein."
                },
                {
                    "pattern": "(?=.*[a-z])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens einen Kleinbuchstaben enthalten."
                },
                {
                    "pattern": "(?=.*[A-Z])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens einen Großbuchstaben enthalten."
                },
                {
                    "pattern": "(?=.*\\d)",
                    "errorMessage": "Das Passwort muss mindestens eine Zahl enthalten."
                },
                {
                    "pattern": "(?=.*[^a-zA-Z\\d])[^\\s]",
                    "errorMessage": "Das Passwort muss mindestens ein Sonderzeichen enthalten."
                }
            ]
        }
    },
    "required": ["resetToken", "password"],
    "additionalProperties": false
}
